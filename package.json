{
  "name": "@co-native-ab/pimdo-ts",
  "version": "0.0.0",
  "description": "MCP server providing AI agents with scoped access to Microsoft Entra PIM (Privileged Identity Management)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "pimdo-ts": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/co-native-ab/pimdo-ts.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "icons": "node scripts/encode-icons.mjs",
    "icons:check": "node scripts/encode-icons.mjs --check",
    "schemas:generate": "tsx scripts/generate-schemas.ts",
    "schemas:check": "tsx scripts/generate-schemas.ts --check",
    "preview": "node scripts/preview-pages.mjs",
    "build": "npm run icons && npm run schemas:generate && node build.mjs",
    "mcpb": "node scripts/bundle-mcpb.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:manifest": "prettier --write manifest.json",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run icons:check && npm run schemas:check && npm run lint && npm run typecheck && npm run test"
  },
  "keywords": [
    "mcp",
    "entra-pim",
    "privileged-identity-management",
    "ai-agents"
  ],
  "author": "co-native-ab",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "open": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "2.1.2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
